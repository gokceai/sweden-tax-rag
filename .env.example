MASTER_ENCRYPTION_KEY=
LLM_MODEL_PATH=meta-llama/Llama-3.2-1B-Instruct

CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=swedish_tax_vectors
CHROMA_DISTANCE=cosine

DYNAMO_ENDPOINT=http://localhost:8000
DYNAMO_REGION=eu-north-1
DYNAMO_TABLE_NAME=SwedishTaxDocuments
DYNAMO_ACCESS_KEY_ID=test
DYNAMO_SECRET_ACCESS_KEY=test

EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=400
CHUNK_OVERLAP=50
LLM_MAX_NEW_TOKENS=250
LLM_TEMPERATURE=0.1
RETURN_CONTEXTS_IN_RESPONSE=false

# none: never return contexts
# redacted: return context metadata only (index + char_count)
# full: return decrypted context text (recommended only for trusted debugging)
CONTEXT_RESPONSE_MODE=none
ENABLE_INGEST_UI=false

# Reconciliation background worker
RECONCILE_AUTORUN=false
RECONCILE_INTERVAL_SECONDS=300

# Admin endpoint protection
# false: no admin key required (recommended for quick local demo/open-source first run)
# true: ingest/reconcile/repair endpoints require X-Admin-Key header
ENFORCE_ADMIN_AUTH=false

# Set a strong value before enabling admin auth in shared/staging/production environments.
# Example (PowerShell): [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Max 256}))
ADMIN_API_KEY=change-me-before-production
