MASTER_ENCRYPTION_KEY=
LLM_MODEL_PATH=meta-llama/Llama-3.2-1B-Instruct
# Docker-only override for model path inside container.
# If you run API in Docker with a local host model directory, set:
# LLM_MODEL_PATH_IN_CONTAINER=/models/Llama-3.2-1B-Instruct
LLM_MODEL_PATH_IN_CONTAINER=
# Host directory where local model files live (used by docker-compose volume mount).
LLM_MODEL_HOST_PATH=./docker/llm_models
# Container root mount path for local models.
LLM_MODEL_CONTAINER_ROOT=/models
API_BASE_URL=http://localhost:8080/api/v1

# ChromaDB embedded storage (no separate server needed)
CHROMA_PERSIST_DIR=./docker/chroma_data
CHROMA_COLLECTION_NAME=swedish_tax_vectors
CHROMA_DISTANCE=cosine

# SQLite encrypted document store (no separate service needed)
SQLITE_DB_PATH=./docker/documents.db

EMBEDDING_MODEL=all-MiniLM-L6-v2
# auto: use CUDA if available, otherwise CPU
# override to cpu or cuda if you want deterministic behavior
EMBEDDING_DEVICE=auto
CHUNK_SIZE=400
CHUNK_OVERLAP=50
LLM_MAX_NEW_TOKENS=250
LLM_TEMPERATURE=0.1
RETURN_CONTEXTS_IN_RESPONSE=false

# none: never return contexts
# redacted: return context metadata only (index + char_count)
# full: return decrypted context text (recommended only for trusted debugging)
CONTEXT_RESPONSE_MODE=none
ENABLE_INGEST_UI=false

# Reconciliation background worker
RECONCILE_AUTORUN=false
RECONCILE_INTERVAL_SECONDS=300

# Admin endpoint protection
# false: no admin key required (recommended for quick local demo/open-source first run)
# true: ingest/reconcile/repair endpoints require X-Admin-Key header
ENFORCE_ADMIN_AUTH=false

# Set a strong value before enabling admin auth in shared/staging/production environments.
# Example (PowerShell): [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Max 256}))
ADMIN_API_KEY=change-me-before-production

# Monitoring targets (SLO baselines)
# API p95 latency target in milliseconds
SLO_API_P95_LATENCY_MS=2500
# Max allowed 5xx error ratio over selected time window (percent)
SLO_API_5XX_ERROR_RATE_PERCENT=1.0
# Minimum retrieval success ratio (percent)
SLO_RETRIEVE_SUCCESS_RATE_PERCENT=99.0
# Allowed count of index mismatch after reconcile
SLO_RECONCILE_MISMATCH_ALLOWED=0
# Maximum allowed age of last reconcile run (minutes)
SLO_RECONCILE_MAX_STALENESS_MINUTES=1440

# Optional Docker resource limits (tune for your machine)
API_CPUS_LIMIT=4.0
API_MEM_LIMIT=6g
PROMETHEUS_CPUS_LIMIT=1.0
PROMETHEUS_MEM_LIMIT=768m
GRAFANA_CPUS_LIMIT=1.0
GRAFANA_MEM_LIMIT=768m
ALERTMANAGER_CPUS_LIMIT=0.5
ALERTMANAGER_MEM_LIMIT=256m

# If API runs inside Docker Compose, override the persist paths to container mount points:
# CHROMA_PERSIST_DIR=/data/chroma
# SQLITE_DB_PATH=/data/documents.db
